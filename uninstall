#!/usr/bin/env bash
# uninstall — remove lazy-pass
set -eo pipefail

INSTALL_DIR="$HOME/.local/share/lazy-pass"
SYMLINK="$HOME/.local/bin/passwords"
PASS_STORE="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
REPO_URL="https://github.com/apapamarkou/lazy-pass"

_remove() {
  local target="$1"
  if [[ -e "$target" || -L "$target" ]]; then
    rm -rf "$target"
    echo "Removed: $target"
  fi
}

_fetch_uninstall() {
  # Piped from curl — download and re-exec with a real TTY
  echo "Downloading uninstall script..."
  local tmp
  tmp="$(mktemp)"
  curl -fsSL "${REPO_URL}/raw/main/uninstall" -o "$tmp"
  chmod +x "$tmp"
  bash "$tmp"
  rm -f "$tmp"
}

main() {
  local self="${BASH_SOURCE[0]-}"
  if [[ -z "$self" || "$self" == "bash" ]]; then
    _fetch_uninstall
    return
  fi

  echo "=== lazy-pass uninstaller ==="

  read -r -n1 -p "Remove lazy-pass installation? [Y/n] " r
  echo
  [[ "${r,,}" == "n" ]] && {
    echo "Aborted."
    exit 0
  }

  _remove "$SYMLINK"
  _remove "$INSTALL_DIR"

  echo ""
  read -r -n1 -p "Also delete password store ($PASS_STORE)? [y/N] " r
  echo
  if [[ "${r,,}" == "y" ]]; then
    read -r -n1 -p "Are you SURE? This is irreversible. [y/N] " confirm
    echo
    if [[ "${confirm,,}" == "y" ]]; then
      _remove "$PASS_STORE"
    else
      echo "Password store kept."
    fi
  fi

  echo "Uninstall complete."
}

self="${BASH_SOURCE[0]-}"
if [[ "$self" == "$0" || -z "$self" ]]; then
  main "$@"
fi
